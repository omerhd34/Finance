generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  profession    String?
  city          String?
  country       String?
  monthStartDay Int           @default(1)
  email         String        @unique
  emailVerified DateTime?
  password      String?
  image         String?       @db.LongText
  phone                 String?
  currency              String        @default("TL")
  notificationsEnabled  Boolean       @default(true)
  planTier                String        @default("free")
  createdAt             DateTime      @default(now())
  paytrOrders       PaytrOrder[]
  transactions    Transaction[]
  goals           Goal[]
  debts           Debt[]
  investments     InvestmentPosition[]
  recurringRules   RecurringRule[]
  accounts         Account[]
  sessions         Session[]
  categoryBudgets  CategoryBudget[]
  notifications    Notification[]
  emailVerificationTokens EmailVerificationToken[]
  aiFinanceAnalyses      AiFinanceAnalysis[]
}

model AiFinanceAnalysis {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  markdown  String   @db.LongText
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Transaction {
  id                String         @id @default(cuid())
  type              String
  amount            Float
  category          String
  description       String?
  date              DateTime       @default(now())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringRuleId   String?
  recurringRule     RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  recurringSlotKey  String?        @unique
  createdAt         DateTime       @default(now())

  @@index([userId, date])
}

model RecurringRule {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  type        String
  amount      Float
  category    String
  description String?
  frequency   String
  interval    Int       @default(1)
  startDate   DateTime
  endDate     DateTime?
  mode        String
  isActive    Boolean   @default(true)
  nextDueDate DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, isActive, nextDueDate])
}

model Goal {
  id            String    @id @default(cuid())
  title         String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model CategoryBudget {
  id                     String           @id @default(cuid())
  userId                 String
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category               String
  monthlyLimit           Float
  alertThresholdPercent  Float            @default(80)
  emailAlertsEnabled     Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  alertLogs              BudgetAlertLog[]

  @@unique([userId, category])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String    @db.Text
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model BudgetAlertLog {
  id         String         @id @default(cuid())
  budgetId   String
  budget     CategoryBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  monthKey   String
  alertType  String
  createdAt  DateTime       @default(now())

  @@unique([budgetId, monthKey, alertType])
  @@index([budgetId])
}

model Debt {
  id            String    @id @default(cuid())
  direction     String
  counterparty  String
  totalAmount   Float
  paidAmount    Float     @default(0)
  dueDate       DateTime?
  note          String?   @db.Text
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([userId, direction])
}

model InvestmentPosition {
  id                     String   @id @default(cuid())
  assetType              String
  goldSubtype            String?
  title                  String
  ticker                 String?
  quantity               Float
  avgCostPerUnitTry      Float
  marketPricePerUnitTry  Float?
  note                   String?  @db.Text
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId, assetType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model PaytrOrder {
  id           String    @id @default(cuid())
  merchantOid  String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountKurus  Int
  currency     String    @default("TL")
  status       String    @default("PENDING")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}
